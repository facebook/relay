//- PersonComponent.js
// Test: Fragment spread on a mixed interface with @waterfall.
// Bicycle is a server type (implements Node) extended to implement
// ClientOnlyInterface. BestFriend is a client resolver type.
// Direct field selection works (see client-edge-to-mixed-interface tests),
// but fragment spreads on the interface should also compile correctly.
graphql`fragment PersonComponent_user on User {
  best_friend @waterfall {
    ...BestFriendFragment
  }
}`

//- BestFriendFragment.js
graphql`fragment BestFriendFragment on ClientOnlyInterface {
  id
  wheels
}`

//- BestFriendResolverFragment.js
graphql`fragment BestFriendResolverFragment_name on User {
  __typename
}`

//- BestFriendResolver.js
/**
 * @relayType BestFriend implements ClientOnlyInterface
 */
export function BestFriend() {}

//- BestFriendWheelsResolver.js
/**
 * @relayField BestFriend.wheels: Int
 */
export function wheels() {}

