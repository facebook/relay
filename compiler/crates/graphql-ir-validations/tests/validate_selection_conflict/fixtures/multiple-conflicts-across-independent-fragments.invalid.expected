  }
}

fragment ContainerA on User {
  ...ConflictA1
  ...ConflictA2
}

# Second conflict: customRenderer with different `mode` arguments
fragment ConflictB1 on User {
  customRenderer(mode: "fast") {
    value
  }
}

fragment ConflictB2 on User {
  customRenderer(mode: "slow") {
    value
  }
}

fragment ContainerB on User {
  ...ConflictB1
  ...ConflictB2
}

%extensions%

type CustomRendererResult {
  value: String
}

extend type User {
  customRenderer(mode: String): CustomRendererResult
}
