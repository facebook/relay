//- schema.graphql
type BlogPost {
  id: ID!
  title: String
}

type FancyBlogPost {
  id: ID!
  title: String
  coverImage: String
}

union PostContent = BlogPost | FancyBlogPost

type Post {
  id: ID!
  content: PostContent
}

type Query {
  blogPost(id: ID): Post
}
