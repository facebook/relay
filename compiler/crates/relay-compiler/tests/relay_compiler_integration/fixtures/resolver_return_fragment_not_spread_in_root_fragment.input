//- UserFoo.js
// Test that @returnFragment must be spread within the @rootFragment.
/**
 * @relayField User.foo: RelayResolverValue
 * @rootFragment UserFoo__id
 * @returnFragment UserFooExternalFragment
 */
graphql`fragment UserFoo__id on User {
  id
}`

//- UserFragment.js
graphql`fragment UserFragment on User {
  foo
}`

//- relay.config.json
{
  "language": "flow",
  "jsModuleFormat": "haste",
  "schema": "schema.graphql",
  "featureFlags": {
    "enable_shadow_resolvers": { "kind": "enabled" }
  }
}

//- schema.graphql
type Query { me: User }
type User { id: ID!, name: String }
