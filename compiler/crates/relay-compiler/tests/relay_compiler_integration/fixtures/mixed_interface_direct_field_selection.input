//- PersonComponent.js
// Test: Direct field selection (id) on a mixed interface with @waterfall.
// Compare with mixed_interface_fragment_spread to see the difference
// in the normalization AST (ClientExtension wrapping).
graphql`fragment PersonComponent_user on User {
  best_friend @waterfall {
    id
    wheels
  }
}`

//- BestFriendResolverFragment.js
graphql`fragment BestFriendResolverFragment_name on User {
  __typename
}`

//- BestFriendResolver.js
/**
 * @relayType BestFriend implements ClientOnlyInterface
 */
export function BestFriend() {}

//- BestFriendWheelsResolver.js
/**
 * @relayField BestFriend.wheels: Int
 */
export function wheels() {}

//- relay.config.json
{
  "language": "flow",
  "jsModuleFormat": "haste",
  "schema": "schema.graphql",
  "schemaExtensions": [
    "schema-extensions"
  ],
  "featureFlags": {
    "relay_resolver_enable_interface_output_type": { "kind": "enabled" }
  }
}

//- schema.graphql
type Query {
  node(id: ID!): Node
}

interface Node {
  id: ID!
}

type User implements Node {
  id: ID!
  name: String
}

type Bicycle implements Node {
  id: ID!
  wheels: Int
}

//- schema-extensions/extension.graphql
interface ClientOnlyInterface implements Node {
  id: ID!
  wheels: Int
}

extend type Bicycle implements ClientOnlyInterface

extend type User {
  best_friend: ClientOnlyInterface @relay_resolver(fragment_name: "BestFriendResolverFragment_name", import_path: "BestFriendResolver")
}
