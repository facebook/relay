//- FooQuery.js
graphql`query FooQuery @exec_time_resolvers {
  me {
    greeting
  }
}`

//- User_greeting.js
/**
 * @relayField User.greeting: RelayResolverValue
 * @rootFragment UserGreetingFragment
 */
graphql`fragment UserGreetingFragment on User {
  id
}`

//- relay.config.json
{
  "language": "flow",
  "jsModuleFormat": "haste",
  "schema": "schema.graphql",
  "featureFlags": {
    "enable_exec_time_resolvers_directive": true
  }
}

//- schema.graphql
type Query { me: User }
type User { id: ID!, name: String }
