// A shadow resolver whose return type is a UNION with a client-extension member
// is a HARD ERROR. relay_resolvers_abstract_types only expands interfaces into
// per-member typed inline arms, not unions, so the client member's selections
// would have nowhere to be routed. The union gate in shadow_transform rejects it
// with ShadowResolverUnionReturnUnsupported; use an interface return instead.
//- UserCombinedPage.js
/**
 * @relayField User.combined_page: PageOrClientPage
 * @rootFragment UserCombinedPageResolverFragment
 * @returnFragment UserCombinedPageReturnFragment
 */
graphql`fragment UserCombinedPageResolverFragment on User {
  page {
    ...UserCombinedPageReturnFragment
  }
}`

