//- relay.config.json
{
   "language": "flow",
   "jsModuleFormat": "haste",
   "schema": "./schema.graphql"
}

//- schema.graphql
type Query {
   me: Viewer
   viewer: Viewer
   node(id: ID!): Node
}

interface Node {
   id: ID!
}

type Viewer implements Node {
   id: ID!
   posts(first: Int, after: String): PostsConnection
}

type PostsConnection {
  count: Int
  edges: [PostEdge]
  pageInfo: PageInfo
}

type PostEdge {
  cursor: String
  node: Page
}

type PageInfo {
  hasPreviousPage: Boolean
  hasNextPage: Boolean
  endCursor: String
  startCursor: String
}

type Page implements Node {
    title: String
    id: ID!
}

