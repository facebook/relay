//- UserClientPage.js
// Shadow resolver whose return interface has a CLIENT-extension implementor only.
//
// `client_page` returns the client interface `IPage`, whose ONLY implementor is
// the CLIENT model type `ClientPage`. The consumer's client selection (expanded
// by relay_resolvers_abstract_types into `... on ClientPage`) is satisfied by the
// `ClientObject` model edge minted in client_edges -- NOT transplanted onto any
// server field, NOT rejected. The artifact is a `ClientEdgeToClientObject` with a
// populated `modelResolvers` map and empty `serverObjectOperations`. The shadowed
// server field `page` carries only the pointer (`__typename id`); no consumer
// selection is transplanted onto it.
/**
 * @relayField User.client_page: IPage
 * @rootFragment UserClientPageResolverFragment
 * @returnFragment UserClientPageReturnFragment
 */
graphql`fragment UserClientPageResolverFragment on User {
  page {
    ...UserClientPageReturnFragment
  }
}`

//- ClientPageResolver.js
/**
 * @relayType ClientPage implements IPage
 */
export function ClientPage() {}

//- ClientPageTitleResolver.js
/**
 * @relayField ClientPage.title: String
 */
export function title() {}

//- UserConsumer.js
graphql`query UserConsumerQuery {
  me {
    client_page {
      title
    }
  }
}`

//- relay.config.json
{
  "language": "flow",
  "jsModuleFormat": "haste",
  "schema": "schema.graphql",
  "schemaExtensions": ["schema-extensions"],
  "featureFlags": {
    "enable_shadow_resolvers": { "kind": "enabled" },
    "relay_resolver_enable_interface_output_type": { "kind": "enabled" }
  }
}

//- schema.graphql
type Query { me: User, node(id: ID!): Node }
interface Node { id: ID! }
type User { name: String, page: Page }
type Page implements Node { id: ID!, title: String }

//- schema-extensions/extension.graphql
interface IPage implements Node {
  id: ID!
  title: String
}
