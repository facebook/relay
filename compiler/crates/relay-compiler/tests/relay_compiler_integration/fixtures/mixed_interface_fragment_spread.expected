//- schema.graphql
type Query {
  node(id: ID!): Node
}

interface Node {
  id: ID!
}

type User implements Node {
  id: ID!
  name: String
}

type Bicycle implements Node {
  id: ID!
  wheels: Int
}

//- schema-extensions/extension.graphql
interface ClientOnlyInterface implements Node {
  id: ID!
  wheels: Int
}

extend type Bicycle implements ClientOnlyInterface

extend type User {
  best_friend: ClientOnlyInterface @relay_resolver(fragment_name: "BestFriendResolverFragment_name", import_path: "BestFriendResolver")
}
