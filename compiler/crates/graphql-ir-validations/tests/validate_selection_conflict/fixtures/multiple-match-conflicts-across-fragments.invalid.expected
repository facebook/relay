# expected-to-throw
# Two independent @match conflicts exist in different fragment chains.
# Both errors should be reported in a single compilation pass.
query TestQuery {
  me {
    ...ContainerA
    ...ContainerB
  }
}

# First conflict: nameRenderer with different match type sets
fragment MatchA1 on User {
  nameRenderer(supported: ["PlainUserNameRenderer"]) @match {
    ...PlainUserNameRenderer_a1 @module(name: "PlainA1.react")
  }
}

fragment MatchA2 on User {
  nameRenderer(supported: ["PlainUserNameRenderer", "MarkdownUserNameRenderer"]) @match {
    ...PlainUserNameRenderer_a2 @module(name: "PlainA2.react")
    ...MarkdownUserNameRenderer_a2 @module(name: "MarkdownA2.react")
  }
}

fragment ContainerA on User {
  ...MatchA1
  ...MatchA2
}

# Second conflict: nameRendererForB with different match type sets
fragment MatchB1 on User {
  nameRendererForB @match(key: "MatchB1_nameRendererForB") {
    ...PlainUserNameRenderer_b1 @module(name: "PlainB1.react")
  }
}

fragment MatchB2 on User {
  nameRendererForB @match(key: "MatchB2_nameRendererForB") {
    ...PlainUserNameRenderer_b2 @module(name: "PlainB2.react")
    ...MarkdownUserNameRenderer_b2 @module(name: "MarkdownB2.react")
  }
}

fragment ContainerB on User {
  ...MatchB1
  ...MatchB2
}

fragment PlainUserNameRenderer_a1 on PlainUserNameRenderer {
  plaintext
}

fragment PlainUserNameRenderer_a2 on PlainUserNameRenderer {
  data {
    text
  }
}

fragment MarkdownUserNameRenderer_a2 on MarkdownUserNameRenderer {
  markdown
}

fragment PlainUserNameRenderer_b1 on PlainUserNameRenderer {
  plaintext
}

fragment PlainUserNameRenderer_b2 on PlainUserNameRenderer {
  data {
    text
  }
}

fragment MarkdownUserNameRenderer_b2 on MarkdownUserNameRenderer {
  markdown
}

%extensions%

extend type User {
  nameRendererForB: UserNameRenderer
}
