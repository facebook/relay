# expected-to-throw
# Two fragments select a field (with `supported` arg) with @match
# but with different @module type conditions. When composed in a
# query, this produces conflicting supported arguments.
query TestQuery {
  me {
    ...RowFragment
  }
}

fragment RowFragment on User {
  id
  ...RootFragment
  nameRenderer(supported: ["PlainUserNameRenderer"]) @match {
    ...PlainUserNameRenderer_row @module(name: "PlainRow.react")
  }
}

fragment RootFragment on User {
  nameRenderer(supported: ["PlainUserNameRenderer", "MarkdownUserNameRenderer"]) @match {
    ...PlainUserNameRenderer_root @module(name: "PlainRoot.react")
    ...MarkdownUserNameRenderer_root @module(name: "MarkdownRoot.react")
  }
}

fragment PlainUserNameRenderer_row on PlainUserNameRenderer {
  plaintext
}

fragment PlainUserNameRenderer_root on PlainUserNameRenderer {
  data {
    text
  }
}

fragment MarkdownUserNameRenderer_root on MarkdownUserNameRenderer {
  markdown
}
