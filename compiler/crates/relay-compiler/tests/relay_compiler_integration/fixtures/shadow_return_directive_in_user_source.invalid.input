//- foo.js

// `@__relay_shadow_return` is internal to the compiler (injected when it
// converts a shadow resolver's `@returnFragment` placeholder before `build_ir`). A
// product author must not be able to hand-write it: doing so would let them mint
// the trusted shadow-return marker and bypass the `...ReturnFragment` authoring
// form. The compiler rejects any user-authored occurrence.
graphql`query fooQuery {
  me @__relay_shadow_return(fragment: "Bar") {
    id
  }
}`

//- relay.config.json
{
   "language": "flow",
   "schema": "./schema.graphql"
}

//- schema.graphql

type Query {
  me: User
}

type User {
  id: ID!
}
