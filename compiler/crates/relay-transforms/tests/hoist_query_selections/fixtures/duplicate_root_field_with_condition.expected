==================================== INPUT ====================================
query TestQuery($skip: Boolean!) {
  viewer @skip(if: $skip) {
    actor {
      id
    }
  }
  me {
    name
    __query {
      viewer {
        actor {
          name
        }
      }
    }
  }
}
==================================== OUTPUT ===================================
query TestQuery(
  $skip: Boolean!
) {
  viewer @skip(if: $skip) {
    actor {
      id
    }
  }
  me {
    name
  }
  viewer {
    actor {
      name
    }
  }
}
