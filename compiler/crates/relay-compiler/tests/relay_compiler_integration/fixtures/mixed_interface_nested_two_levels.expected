//- PersonComponent.js
// Test: Two levels of nested abstract fields on mixed interfaces.
// IPerson.pet: IAnimal, IAnimal.toy: IToy.
// DogPerson (server) has pet: Dog; Dog (server) has toy: DogToy.
// CatPerson (client) has pet: Cat; Cat (client) has toy: CatToy.
// After filtering, inside DogPerson: pet should only have ... on Dog,
// and inside Dog: toy should only have ... on DogToy. No CatToy
// should appear inside the Dog branch.
graphql`query PersonComponentQuery {
  person @waterfall {
    pet {
      toy { name }
    }
  }
}`

