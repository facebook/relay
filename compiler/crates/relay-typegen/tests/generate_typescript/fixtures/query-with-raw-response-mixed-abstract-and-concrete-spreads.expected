==================================== INPUT ====================================
# Tests raw response type generation when a field has both interface and
# concrete type spreads. The concrete branches that implement the interface
# should include the interface fields as non-optional.
# Story implements FeedUnit & Node, so it should get FeedUnit fields merged in.
# PhotoStory also implements FeedUnit & Node.
# The catch-all should have FeedUnit fields as optional.
query ExampleQuery @raw_response_type {
  node(id: "1") {
    __typename
    ... on FeedUnit {
      tracking
    }
    ... on Story {
      name
    }
    ... on PhotoStory {
      photo {
        uri
      }
    }
  }
}
==================================== OUTPUT ===================================
export type ExampleQuery$variables = Record<PropertyKey, never>;
export type ExampleQuery$data = {
  readonly node: {
    readonly __typename: string;
    readonly name?: string | null | undefined;
    readonly photo?: {
      readonly uri: string | null | undefined;
    } | null | undefined;
    readonly tracking?: string | null | undefined;
  } | null | undefined;
};
export type ExampleQuery$rawResponse = {
  readonly node: {
    readonly __typename: "PhotoStory";
    readonly __isFeedUnit: "PhotoStory";
    readonly id: string;
    readonly photo: {
      readonly uri: string | null | undefined;
    } | null | undefined;
    readonly tracking: string | null | undefined;
  } | {
    readonly __typename: "Story";
    readonly __isFeedUnit: "Story";
    readonly id: string;
