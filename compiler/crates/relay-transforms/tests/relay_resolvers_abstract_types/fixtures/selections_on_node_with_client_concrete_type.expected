==================================== INPUT ====================================
# relay-resolver-enable-interface-output-type

query selectionsOnNodeQuery {
    node(id: 4) {
        __typename
        id
    }
}

# %extensions%

type ClientType implements Node {
    id: ID!
}
==================================== OUTPUT ===================================
query selectionsOnNodeQuery {
  node(id: 4) {
    __typename
    ... on Bicycle {
      id
    }
    ... on Comment {
      id
    }
    ... on Feedback {
      id
    }
    ... on Page {
      id
    }
    ... on PhotoStory {
      id
    }
    ... on Story {
      id
    }
    ... on User {
      id
    }
    ... on FetchableType {
      id
    }
    ... on ClientType {
      id
    }
  }
}
