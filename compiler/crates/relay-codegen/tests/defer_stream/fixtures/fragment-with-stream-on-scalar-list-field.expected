==================================== INPUT ====================================
query QueryWithFragmentWithStreamOnScalarList($id: ID!) {
  node(id: $id) {
    id
    ...UserFragment
  }
}

fragment UserFragment on User {
  id
  emailAddresses @stream(initialCount: 1)
}
