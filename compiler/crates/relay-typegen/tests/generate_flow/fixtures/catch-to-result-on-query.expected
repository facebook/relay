==================================== INPUT ====================================
query MyQuery @catch {
  me {
    id
    name
  }
}
==================================== OUTPUT ===================================
import type { Result } from "relay-runtime";
export type MyQuery$variables = {};
export type MyQuery$data = Result<{
  readonly me: ?{
    readonly id: string,
    readonly name: ?string,
  },
}, unknown>;
export type MyQuery = {
  response: MyQuery$data,
  variables: MyQuery$variables,
};
