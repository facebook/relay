//- schema.graphql
interface Node {
  id: ID!
}

type MarkdownCommentBody {
  markdown: String
}

type PlaintextCommentBody {
  text: String
}

union CommentBody = MarkdownCommentBody | PlaintextCommentBody

type Comment implements Node {
  id: ID!
  body: CommentBody
}

type Query {
  node(id: ID): Node
}
