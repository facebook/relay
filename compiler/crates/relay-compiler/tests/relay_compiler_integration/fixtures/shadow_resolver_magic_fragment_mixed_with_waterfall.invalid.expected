// @waterfall on a shadow field is a HARD ERROR even when the return interface has
// a client-extension implementor. A shadow field is never a waterfall: its
// consumer selections are fetched in the main operation (server arm transplanted,
// client arm read via the model edge), so there is no client query to gate. The
// waterfall-forbidden check fires before the routing splits on the implementor
// set, so the mixed (server + client) case errors just like the pure-server case.
//- UserCombinedPage.js
/**
 * @relayField User.combined_page: IPage
 * @rootFragment UserCombinedPageResolverFragment
 * @returnFragment UserCombinedPageReturnFragment
 */
graphql`fragment UserCombinedPageResolverFragment on User {
  page {
    ...UserCombinedPageReturnFragment
  }
}`

//- ClientPageResolver.js
/**
 * @relayType ClientPage implements IPage
 */
export function ClientPage() {}

//- ClientPageTitleResolver.js
/**
