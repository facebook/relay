==================================== INPUT ====================================
# When spreading on an interface inside a union in @raw_response_type,
# fields from the interface should remain required (not optional)
# on concrete type branches that implement the interface.
# Story implements MaybeNodeInterface (has `name`), but FakeNode and NonNode do not.
query ExampleQuery @raw_response_type {
  maybeNode {
    __typename
    ... on MaybeNodeInterface {
      name
    }
  }
}
==================================== OUTPUT ===================================
export type ExampleQuery$variables = {};
export type ExampleQuery$data = {
  readonly maybeNode: ?{
    readonly __typename: string,
    readonly name?: ?string,
  },
};
export type ExampleQuery$rawResponse = {
  readonly maybeNode: ?({
    readonly __typename: "FakeNode",
    readonly id: string,
  } | {
    readonly __typename: string,
    readonly __isMaybeNodeInterface?: string,
    readonly __isNode?: string,
    readonly id?: string,
    readonly name?: ?string,
  }),
};
export type ExampleQuery = {
  rawResponse: ExampleQuery$rawResponse,
  response: ExampleQuery$data,
  variables: ExampleQuery$variables,
};
