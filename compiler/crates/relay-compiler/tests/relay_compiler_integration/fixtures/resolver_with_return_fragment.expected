// Test that @returnFragment docblock tag is parsed on a resolver.
// Note: @returnFragment requires @rootFragment to be present and
// the return fragment must be spread within the root fragment.
/**
 * @relayField User.foo: RelayResolverValue
 * @rootFragment UserFoo__id
 * @returnFragment UserFooExternalFragment
 */
graphql`fragment UserFoo__id on User {
  id
  ...UserFooExternalFragment
}`

