// A non-overlapping SERVER-type inline arm under a shadow resolver field STILL
// hard-errors with ShadowReturnIncompatibleInlineFragmentType. The interface
// `IPage` is implemented by two server types, `Page` and `Article`, but the
// resolver shadows the server field `User.page` (concrete type `Page`). The
// consumer's `... on Article` arm cannot overlap the shadowed `Page` type, so it
// cannot be transplanted onto the shadowed server field. This proves the
// partition narrows the drop ONLY to client-extension arms and does not silently
// drop a genuinely-incompatible server arm.
//- UserCombinedPage.js
/**
 * @relayField User.combined_page: IPage
 * @rootFragment UserCombinedPageResolverFragment
 * @returnFragment UserCombinedPageReturnFragment
 */
graphql`fragment UserCombinedPageResolverFragment on User {
  page {
    ...UserCombinedPageReturnFragment
  }
}`

//- UserConsumer.js
graphql`query UserConsumerQuery {
  me {
    combined_page {
      ... on Article {
        title
      }
    }
  }
}`

//- relay.config.json
{
  "language": "flow",
  "jsModuleFormat": "haste",
  "schema": "schema.graphql",
  "schemaExtensions": ["schema-extensions"],
  "featureFlags": {
    "enable_shadow_resolvers": { "kind": "enabled" },
    "relay_resolver_enable_interface_output_type": { "kind": "enabled" }
  }
}

//- schema.graphql
type Query { me: User, node(id: ID!): Node }
interface Node { id: ID! }
type User { name: String, page: Page }
type Page implements Node { id: ID!, title: String }
type Article implements Node { id: ID!, title: String }

//- schema-extensions/extension.graphql
interface IPage implements Node {
  id: ID!
  title: String
}

extend type Page implements IPage
extend type Article implements IPage
