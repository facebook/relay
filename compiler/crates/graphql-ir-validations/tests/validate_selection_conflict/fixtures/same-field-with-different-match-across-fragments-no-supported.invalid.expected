# expected-to-throw
# Two fragments select a field (without `supported` arg) with @match
# but with different @module type conditions. This should still be
# caught even though the field has no `supported` argument.
query TestQuery {
  me {
    ...RowFragment
  }
}

fragment RowFragment on User {
  id
  ...RootFragment
  nameRendererNoSupported @match(key: "RowFragment_nameRendererNoSupported") {
    ...PlainUserNameRenderer_row @module(name: "PlainRow.react")
  }
}

fragment RootFragment on User {
  nameRendererNoSupported @match(key: "RootFragment_nameRendererNoSupported") {
    ...PlainUserNameRenderer_root @module(name: "PlainRoot.react")
    ...MarkdownUserNameRenderer_root @module(name: "MarkdownRoot.react")
  }
}

fragment PlainUserNameRenderer_row on PlainUserNameRenderer {
  plaintext
}

fragment PlainUserNameRenderer_root on PlainUserNameRenderer {
  data {
    text
  }
}

fragment MarkdownUserNameRenderer_root on MarkdownUserNameRenderer {
  markdown
}

%extensions%

extend type User {
  nameRendererNoSupported: UserNameRenderer
}
