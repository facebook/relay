==================================== INPUT ====================================
query TestQuery($showUser: Boolean!, $showViewer: Boolean!) {
  me @include(if: $showUser) {
    ...UserFragment
  }
}

fragment UserFragment on User {
  name
  __query @skip(if: $showViewer) {
    viewer {
      actor {
        name
      }
    }
  }
}
==================================== OUTPUT ===================================
query TestQuery(
  $showUser: Boolean!
  $showViewer: Boolean!
) {
  me @include(if: $showUser) {
    ...UserFragment
  }
  viewer @skip(if: $showViewer) {
    actor {
      name
    }
  }
}

fragment UserFragment on User {
  name
}
