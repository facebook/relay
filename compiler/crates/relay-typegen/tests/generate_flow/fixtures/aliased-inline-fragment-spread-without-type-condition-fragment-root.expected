==================================== INPUT ====================================
fragment Foo on User {
  ... @alias(as: "aliased_fragment") {
    name
  }
}
==================================== OUTPUT ===================================
import type { FragmentType } from "relay-runtime";
declare export opaque type Foo$fragmentType: FragmentType;
export type Foo$data = {
  readonly aliased_fragment: {
    readonly name: ?string,
  },
  readonly $fragmentType: Foo$fragmentType,
};
export type Foo$key = {
  readonly $data?: Foo$data,
  readonly $fragmentSpreads: Foo$fragmentType,
  ...
};
